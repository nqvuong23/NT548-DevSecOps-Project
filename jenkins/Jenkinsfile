pipeline {
    // BƯỚC 1: Định nghĩa Pod Template cho Dynamic Agent chạy trên GKE
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  # Ép Pod Agent chạy vào platform-pool theo thiết kế hệ thống
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
        - matchExpressions:
          - key: pool
            operator: In
            values:
            - platform
  # Cần Toleration vì node pool này có Taint "NoSchedule"
  tolerations:
  - key: "pool"
    operator: "Equal"
    value: "platform"
    effect: "NoSchedule"
  
  containers:
  # Container JNLP mặc định để kết nối với Jenkins Controller
  - name: jnlp
    image: jenkins/inbound-agent:3256.v88a_f6e922152-1-jdk17
  
  # Thêm container Gitleaks để thực hiện quét Secret (Task 2.2 - Step 1)
  - name: gitleaks
    image: zricethezav/gitleaks:v8.18.2
    command:
    - sleep
    args:
    - infinity
  - name: sonar-scanner
    image: sonarsource/sonar-scanner-cli:5
    command:
    - sleep
    args:
    - infinity
  
  # Thêm container Checkov để quét mã nguồn IaC (Terraform)
  - name: checkov
    image: bridgecrew/checkov:3.2.111
    command:
    - sleep
    args:
    - infinity

  # Thêm container Trivy để quét Dependency và Docker Image
  - name: trivy
    image: aquasec/trivy:0.50.1
    command:
    - sleep
    args:
    - infinity
"""
        }
    }

    stages {
        // Stage mặc định: Kéo code từ GitHub về không gian làm việc của Agent
        stage('Git Checkout') {
            steps {
                checkout scm
            }
        }

        // BƯỚC 2: Stage thực hiện quét Secret (Task 2.2 - Step 2)
        stage('Secret Scanning - Gitleaks') {
            when { changeset "app_src/**" }
            steps {
                container('gitleaks') {
                    script {
                        echo ">>> Đang bắt đầu quét Secret bằng Gitleaks..."
                        def exitCode = sh(
                            script: 'gitleaks detect --source ./app_src --config .gitleaks.toml --verbose --report-format json --report-path gitleaks-report.json',
                            returnStatus: true
                        )
                        if (exitCode == 1) {
                            error "Gitleaks phát hiện secret! Xem file gitleaks-report.json trong Artifacts để biết chi tiết."
                        } else if (exitCode != 0) {
                            error "Gitleaks lỗi không xác định, exit code: ${exitCode}. Xem file gitleaks-report.json trong Artifacts để biết chi tiết."
                        }
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'gitleaks-report.json', allowEmptyArchive: true
                }
            }
        }

        stage('SAST - SonarQube') {
            when { changeset "app_src/**" }
            steps {
                container('sonar-scanner') {
                    script {
                        echo ">>> Đang bắt đầu phân tích mã nguồn với SonarQube..."
                        
                        // Lấy token từ két sắt của Jenkins (tránh hardcode)
                        withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                            // Chạy lệnh quét và truyền token vào
                            sh 'sonar-scanner -Dsonar.token=$SONAR_TOKEN'
                        }
                    }
                }
            }
        }

        stage('Quality Gate Check') {
            when { changeset "app_src/**" }
            steps {
                // Đặt thời gian chờ tối đa là 10 phút để tránh Pipeline bị treo vĩnh viễn
                timeout(time: 10, unit: 'MINUTES') {
                    script {
                        echo ">>> Đang chờ kết quả Quality Gate từ SonarQube Webhook..."
                        // Lệnh này ép Jenkins dừng lại, ngồi đợi Webhook gọi sang.
                        // Nếu SonarQube báo FAIL -> abortPipeline: true sẽ đánh rớt luôn Jenkins Pipeline.
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline bị hủy vì không vượt qua được SonarQube Quality Gate! Trạng thái: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('IaC Scan - Checkov') {
            when { changeset "terraform/**" }
            steps {
                container('checkov') {
                    script {
                        echo ">>> Đang bắt đầu quét mã nguồn Terraform bằng Checkov..."
                        
                        // Chạy Checkov quét thư mục terraform (-d ./terraform) và xuất kết quả dạng JSON (-o json)
                        // Dùng returnStatus: true để pipeline không bị văng ngay lập tức nếu Checkov phát hiện rủi ro,
                        // từ đó mới có thể chạy tiếp block post {} bên dưới để lưu file báo cáo.
                        def exitCode = sh(
                            script: 'checkov -d ./terraform -o json > checkov-report.json',
                            returnStatus: true
                        )
                        
                        if (exitCode == 1) {
                            error "Checkov phát hiện rủi ro IaC! Xem checkov-report.json."
                        } else if (exitCode != 0) {
                            error "Checkov lỗi không xác định, exit code: ${exitCode}. Xem checkov-report.json để biết chi tiết."
                        } else {
                            echo "Tuyệt vời! Không phát hiện rủi ro IaC nào."
                        }
                    }
                }
            }
            post {
                always {
                    // Lưu lại file report JSON để lát nữa có thể đưa lên DefectDojo
                    archiveArtifacts artifacts: 'checkov-report.json', allowEmptyArchive: true
                }
            }
        }

        stage('SCA - Trivy Dependency Scan') {
            when { changeset "app_src/**" }
            steps {
                container('trivy') {
                    script {
                        echo ">>> Đang bắt đầu quét Dependency bằng Trivy..."
                        
                        // Chạy quét Trivy FS 
                        def exitCode = sh(
                            script: 'trivy fs --format json --output trivy-fs-report.json --exit-code 1 --severity HIGH,CRITICAL ./app_src',
                            returnStatus: true
                        )
                        
                        if (exitCode != 0) {
                            error "Trivy phát hiện lỗ hổng mức độ HIGH/CRITICAL trong thư viện/dependency! Đã dừng Pipeline. Xem trivy-fs-report.json để biết chi tiết."
                        } else {
                            echo "Tuyệt vời! Không phát hiện lỗ hổng nghiêm trọng nào trong Dependency."
                        }
                    }
                }
            }
            post {
                always {
                    // Lưu lại file report JSON để đẩy lên DefectDojo
                    archiveArtifacts artifacts: 'trivy-fs-report.json', allowEmptyArchive: true
                }
            }
        }

        // =========================================================================
        // [CHUẨN BỊ CHO TASK 2.4] STAGE BUILD DOCKER IMAGE SẼ ĐƯỢC THÊM VÀO VỊ TRÍ NÀY
        // stage('Build Docker Image') { ... }
        // =========================================================================

        stage('Image Scan - Trivy') {
            when { changeset "app_src/**" }
            steps {
                container('trivy') {
                    script {
                        echo ">>> Đang bắt đầu quét Docker Image bằng Trivy..."
                        
                        // -------------------------------------------------------------------------
                        // [LƯU Ý CHO SAU NÀY KHI LÀM TASK 2.4]
                        // Hiện tại đang dùng image alpine:3.18 để quét nháp.
                        // Khi làm Task 2.4, đổi TEST_IMAGE thành tên image vừa build xong.
                        // Ví dụ: def TEST_IMAGE = "harbor.vuongdevops.io.vn/devsecops/my-app:latest"
                        // -------------------------------------------------------------------------
                        def TEST_IMAGE = "alpine:3.18"
                        
                        // Chạy lệnh Trivy Image Scan với ngưỡng bảo mật HIGH, CRITICAL
                        def exitCode = sh(
                            script: "trivy image --format json --output trivy-image-report.json --exit-code 1 --severity HIGH,CRITICAL ${TEST_IMAGE}",
                            returnStatus: true
                        )
                        
                        if (exitCode != 0) {
                            error "Trivy phát hiện lỗ hổng mức độ HIGH/CRITICAL trong Docker Image! Đã dừng Pipeline. Xem trivy-image-report.json để biết chi tiết."
                        } else {
                            echo "Tuyệt vời! Docker Image an toàn, không có lỗ hổng nghiêm trọng."
                        }
                    }
                }
            }
            post {
                always {
                    // Lưu lại file report JSON để lát nữa đẩy lên DefectDojo
                    archiveArtifacts artifacts: 'trivy-image-report.json', allowEmptyArchive: true
                }
            }
        }
    }
}